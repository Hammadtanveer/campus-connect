rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== AUTH HELPERS ==========
    function isAuthenticated() {
      return request.auth != null;
    }

    function userPermissions() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions;
    }

    function hasPermission(key) {
      return isAuthenticated() &&
             userPermissions() is list &&
             ('*:*:*' in userPermissions() || key in userPermissions());
    }

    function hasSocietyManagePermission(societyId) {
      return hasPermission('society:*:manage') || hasPermission('society:' + societyId + ':manage');
    }

    // ========== USERS COLLECTION ==========
    match /users/{userId} {
      // Anyone can read basic user info
      allow read: if isAuthenticated();

      // Users can create their own profile during signup
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Users can update their own profile (except admin fields)
      allow update: if isAuthenticated() && request.auth.uid == userId &&
                       !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['role', 'permissions', 'status', 'createdBy',
                                  'expiresAt', 'suspendedBy', 'revokedBy']);

      // Only super admin can modify admin-related fields
      allow update: if hasPermission('admin:access') && userId != request.auth.uid;

      allow delete: if hasPermission('admin:access');
    }

    // ========== ADMIN INVITATIONS COLLECTION ==========
    match /admin_invitations/{invitationId} {
      allow create: if hasPermission('admin:access');
      allow read: if hasPermission('admin:access');
      allow update, delete: if hasPermission('admin:access');
    }

    // ========== ADMIN AUDIT LOG COLLECTION ==========
    match /admin_audit_log/{logId} {
      // Only admins can read audit logs
      allow read: if hasPermission('admin:access');

      // Only Cloud Functions can write (deny all client writes)
      allow write: if false;
    }

    // ========== MEETINGS & ANNOUNCEMENTS COLLECTION ==========
    match /events/{eventId} {
      // Anyone authenticated can read events
      allow read: if isAuthenticated();

      // Can create if has permission
      allow create: if hasPermission('meetings:manage');

      allow update: if hasPermission('meetings:manage');

      allow delete: if hasPermission('meetings:manage');
    }

    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasPermission('meetings:manage');
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasPermission('meetings:manage');
    }

    // ========== NOTES COLLECTION ==========
    match /notes/{noteId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.uploaderId == request.auth.uid &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 200 &&
        request.resource.data.subject is string &&
        request.resource.data.semester is string &&
        request.resource.data.fileUrl is string &&
        request.resource.data.cloudinaryPublicId is string &&
        hasPermission('notes:manage');

      allow delete: if isAuthenticated() &&
        (resource.data.uploaderId == request.auth.uid ||
         hasPermission('notes:manage'));

      allow update: if isAuthenticated() &&
        ((request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['downloads', 'views'])) ||
         hasPermission('notes:manage'));
    }

    // ========== SENIORS COLLECTION ==========
    match /seniors/{seniorId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasPermission('seniors:manage');
    }

    // ========== PLACEMENTS COLLECTION ==========
    match /placements/{placementId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasPermission('placements:manage');
    }

    // ========== SOCIETIES COLLECTION ==========
    match /societies/{societyId} {
      allow read: if true;

      allow create: if hasSocietyManagePermission(societyId);

      allow update, delete: if hasSocietyManagePermission(societyId);

      // Society events nested under each society
      match /events/{eventId} {
        function hasValidSocietyEventPayload() {
          return request.resource.data.societyId is string && request.resource.data.societyId == societyId &&
                 request.resource.data.societyName is string && request.resource.data.societyName.size() > 0 &&
                 request.resource.data.name is string && request.resource.data.name.size() > 0 &&
                 request.resource.data.date is string && request.resource.data.date.size() > 0 &&
                 request.resource.data.time is string && request.resource.data.time.size() > 0 &&
                 request.resource.data.venue is string && request.resource.data.venue.size() > 0 &&
                 request.resource.data.coordinator is string && request.resource.data.coordinator.size() > 0 &&
                 request.resource.data.convener is string && request.resource.data.convener.size() > 0 &&
                 request.resource.data.register is string && request.resource.data.register.size() > 0 &&
                 request.resource.data.posterUrl is string && request.resource.data.posterUrl.size() > 0;
        }

        allow read: if isAuthenticated();

        // Society managers can create and update
        allow create: if isAuthenticated() && hasSocietyManagePermission(societyId) &&
                      request.resource.data.createdBy == request.auth.uid &&
                      hasValidSocietyEventPayload();

        allow update: if isAuthenticated() && hasSocietyManagePermission(societyId) &&
                      hasValidSocietyEventPayload() &&
                      request.resource.data.createdBy == resource.data.createdBy &&
                      request.resource.data.createdByRole == resource.data.createdByRole &&
                      request.resource.data.createdAt == resource.data.createdAt;

        allow delete: if hasSocietyManagePermission(societyId);
      }
    }

    // ========== REGISTRATIONS ==========
    match /registrations/{regId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ========== MENTORSHIP ==========
    match /mentorship_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.receiverId == request.auth.uid || resource.data.senderId == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }

    match /mentorship_connections/{connectionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.participants;
    }

    // ========== ACTIVITY LOGS ==========
    match /activity_logs/{logId} {
      allow read: if hasPermission('admin:access');
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ========== NOTIFICATION QUEUE ==========
    match /notification_queue/{itemId} {
      allow create: if hasPermission('admin:access');
      allow read: if hasPermission('admin:access');
      allow update, delete: if false;
    }
  }
}
