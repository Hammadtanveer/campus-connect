rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function userPermissions() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions;
    }
    function hasPermission(key) {
      return isAuthenticated() &&
             userPermissions() is list &&
             ('*:*:*' in userPermissions() || key in userPermissions());
    }
    function hasSocietyManagePermission(societyId) {
      return hasPermission('society:*:manage') || hasPermission('society:' + societyId + ':manage');
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId &&
                       !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['role', 'permissions', 'status', 'createdBy',
                                  'expiresAt', 'suspendedBy', 'revokedBy']);
      allow update: if hasPermission('admin:access') && userId != request.auth.uid;
      allow delete: if hasPermission('admin:access') || request.auth.uid == userId;
    }

    match /admin_invitations/{invitationId} {
      allow create, read, update, delete: if hasPermission('admin:access');
    }

    match /admin_audit_log/{logId} {
      allow read: if hasPermission('admin:access');
      allow write: if false;
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasPermission('meetings:manage');
    }

    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasPermission('meetings:manage');
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasPermission('meetings:manage');
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.uploaderId == request.auth.uid &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 200 &&
        request.resource.data.subject is string &&
        request.resource.data.semester is string &&
        request.resource.data.fileUrl is string &&
        request.resource.data.cloudinaryPublicId is string &&
        hasPermission('notes:manage');
      allow delete: if isAuthenticated() &&
        (resource.data.uploaderId == request.auth.uid || hasPermission('notes:manage'));
      allow update: if isAuthenticated() &&
        ((request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloads', 'views'])) ||
         hasPermission('notes:manage'));
    }

    match /seniors/{seniorId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasPermission('seniors:manage');
    }

    match /placements/{placementId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasPermission('placements:manage');
    }

    match /societies/{societyId} {
      allow read: if isAuthenticated();
      allow create: if hasSocietyManagePermission(societyId);
      allow update, delete: if hasSocietyManagePermission(societyId);

      match /public/{docId} {
        allow read: if true;
        allow write: if false;
      }
      match /private/{docId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if hasSocietyManagePermission(societyId);
      }
      match /events/{eventId} {
        function hasValidSocietyEventPayload() {
          return request.resource.data.societyId is string &&
                 request.resource.data.societyId == societyId &&
                 request.resource.data.societyName is string &&
                 request.resource.data.societyName.size() > 0 &&
                 request.resource.data.name is string &&
                 request.resource.data.name.size() > 0 &&
                 request.resource.data.date is string &&
                 request.resource.data.date.size() > 0 &&
                 request.resource.data.time is string &&
                 request.resource.data.time.size() > 0 &&
                 request.resource.data.venue is string &&
                 request.resource.data.venue.size() > 0 &&
                 request.resource.data.coordinator is string &&
                 request.resource.data.coordinator.size() > 0 &&
                 request.resource.data.convener is string &&
                 request.resource.data.convener.size() > 0 &&
                 request.resource.data.register is string &&
                 request.resource.data.register.size() > 0 &&
                 request.resource.data.posterUrl is string &&
                 request.resource.data.posterUrl.size() > 0;
        }
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && hasSocietyManagePermission(societyId) &&
                      request.resource.data.createdBy == request.auth.uid &&
                      hasValidSocietyEventPayload();
        allow update: if isAuthenticated() && hasSocietyManagePermission(societyId) &&
                      hasValidSocietyEventPayload() &&
                      request.resource.data.createdBy == resource.data.createdBy &&
                      request.resource.data.createdByRole == resource.data.createdByRole &&
                      request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if hasSocietyManagePermission(societyId);
      }
    }

    match /registrations/{regId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /mentorship_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.receiverId == request.auth.uid || resource.data.senderId == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }

    match /mentorship_connections/{connectionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.participants;
    }

    match /activity_logs/{logId} {
      allow read: if hasPermission('admin:access');
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /notification_queue/{itemId} {
      allow create, read: if hasPermission('admin:access');
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update: if hasPermission('admin:access');
      allow delete: if false;
    }
  }
}
